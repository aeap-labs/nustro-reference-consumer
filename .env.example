# ── Operator (AEA/P Platform) ────────────────────────────────────────────
# Base URL of the Operator this agent talks to. Default: https://api.nustro.ai
OPERATOR_URL=https://api.nustro.ai
# OPTIONAL — dispute-only. The purchase/confirm flow authenticates AS the agent
# (certificate + request-bound proof, Operator Ref v1.2 §4.5), so no key is
# needed for it. This management key is used ONLY to file a dispute.
# Format: nustro_sandbox_<hex> (sandbox) or nustro_live_<hex> (production).
# NUSTRO_PRINCIPAL_KEY=nustro_sandbox_your_key_here

# ── This agent (Consumer / Buy-bot) ──────────────────────────────────────
CONSUMER_DID=did:aeap:your-consumer-agent-uuid-here
# keys/private_key.pem + keys/certificate.jwt = this agent's key + cert
# (returned once at activation / rotate-key).

# ── Counterparty (Provider / Sell-bot) ───────────────────────────────────
PROVIDER_DID=did:aeap:your-provider-agent-uuid-here
PROVIDER_BASE_URL=http://localhost:5001

# ── On-chain (payment execution) ─────────────────────────────────────────
CONSUMER_WALLET_PRIVATE_KEY=0xyour_wallet_private_key_here
# OPTIONAL — defaults to the public RPC https://sepolia.base.org when unset, so
# the demo runs out-of-the-box. Public RPCs rate-limit; set your own
# Alchemy/Infura URL for reliable use.
# BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/your-key-here
